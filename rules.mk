# rules.mk — Keychron Q11 custom keymap

# Enable tap dance (multi-tap Shift keys)
TAP_DANCE_ENABLE = yes

# Enable Caps Word
CAPS_WORD_ENABLE = yes

# Enable RGB matrix (for per-layer indicators)
RGB_MATRIX_ENABLE = yes

# Enable the rotary encoder (knob)
ENCODER_ENABLE = yes

# Optional: enable console output for debugging
# Uncomment during development, disable before final flash
# CONSOLE_ENABLE = yes
